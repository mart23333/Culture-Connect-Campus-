<%- include("layout", {
  title: "Login",
  body: `
    <section class="card">
      <h2>Login</h2>
      <form method="POST" action="/login" class="form">
        <label>Email
          <input name="email" type="email" required />
        </label>

        <label>Password
          <input name="password" type="password" required />
        </label>

        <button class="btn" type="submit">Login</button>
      </form>
    </section>
  `
}) %>